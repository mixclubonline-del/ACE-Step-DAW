{
  "name": "ace-step-daw",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:wasm && tsc -b && vite build",
    "build:wasm": "wasm-pack build crates/ace-dsp-wasm --target web --out-dir ../../src/wasm/pkg --release && node -e \"require('fs').copyFileSync('src/wasm/pkg/ace_dsp_wasm_bg.wasm','public/ace_dsp_wasm_bg.wasm')\"",
    "build:wasm:dev": "wasm-pack build crates/ace-dsp-wasm --target web --out-dir ../../src/wasm/pkg --dev && node -e \"require('fs').copyFileSync('src/wasm/pkg/ace_dsp_wasm_bg.wasm','public/ace_dsp_wasm_bg.wasm')\"",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:all": "vitest run && npx playwright test",
    "test:coverage": "vitest run --coverage",
    "qa:runlist": "node scripts/qa/generate-runlist.mjs",
    "qa:validate": "node scripts/qa/validate-story-assets.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "docs:dev": "vitepress dev website",
    "docs:build": "vitepress build website",
    "docs:preview": "vitepress preview website",
    "dashboard": "tsx dashboard/server.ts",
    "dashboard:build": "vite build --config dashboard/vite.config.ts"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@kabelsalat/web": "^0.3.3",
    "@strudel/codemirror": "^1.3.0",
    "@strudel/core": "^1.2.6",
    "@strudel/mini": "^1.2.6",
    "@strudel/repl": "^1.3.0",
    "@strudel/soundfonts": "^1.3.0",
    "@strudel/tonal": "^1.2.6",
    "@strudel/transpiler": "^1.2.6",
    "@strudel/webaudio": "^1.3.0",
    "@tauri-apps/api": "^2.10.1",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "codemirror": "^6.0.2",
    "idb-keyval": "^6.2.0",
    "mp4-muxer": "^5.2.2",
    "node-pty": "^1.2.0-beta.12",
    "onnxruntime-web": "^1.24.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rubberband-wasm": "^3.3.0",
    "signalsmith-stretch": "^1.3.2",
    "uuid": "^11.0.0",
    "web-demuxer": "^4.0.0",
    "xterm": "^5.3.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/webmidi": "^2.1.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0",
    "ws": "^8.20.0"
  },
  "license": "AGPL-3.0-or-later"
}
